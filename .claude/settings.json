{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "Write",
      "Edit",
      "Bash",
      "Agent",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Read(python/ctpc-api/.env)",
      "Read(**/credentials*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(sudo *)",
      "Bash(shutdown *)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/scan-safety-hook.ts \"$CLAUDE_TOOL_INPUT\"",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/tube-safety-hook.ts \"$CLAUDE_TOOL_INPUT\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/winwerth-safety-hook.ts \"$CLAUDE_TOOL_INPUT\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/damage-control-autopilot.ts \"$CLAUDE_TOOL_OUTPUT\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "SessionStart",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/config-validator.ts",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}