{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@autopilot/types": ["../../packages/autopilot-types/src"],
      "@autopilot/ws": ["../../packages/autopilot-ws/src"]
