# AutoPilot Network Configuration
# Leave empty for auto-detection (recommended)
# Auto-detection uses window.location.hostname + known ports,
# so it works when iPad connects to Pi WiFi or local dev.

# Set these only if auto-detection doesn't work:
# NEXT_PUBLIC_CT_PC_URL=http://192.168.4.x:4802
# NEXT_PUBLIC_PI_URL=http://192.168.4.1:4801
